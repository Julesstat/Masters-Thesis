extract_irr <- function(model, label, exposure_var) {
  coefs <- summary(model)$coefficients
  beta  <- coef(model)[exposure_var]
  se    <- coefs[exposure_var, "Std. Error"]
  p_val <- coefs[exposure_var, ncol(coefs)]
  
  data.table(
    definition = label,
    IRR        = round(exp(beta), 3),
    CI_low     = round(exp(beta - 1.96 * se), 3),
    CI_high    = round(exp(beta + 1.96 * se), 3),
    pct_change = round((exp(beta) - 1) * 100, 1),
    p_value    = round(p_val, 4)
  )
}

# Weighted models
