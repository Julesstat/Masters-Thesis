# Filter to summer months only (June=06, July=07, August=08)
nc_files_summer <- nc_files[grepl("_(06|07|08)\\.nc$", nc_files)]

# Extract year from filename
years <- unique(sub(".*era5_(\\d{4})_.*", "\\1", nc_files_summer))

# For each year, load the 3 summer months, stack, take cell-wise max
summer_max_list <- lapply(years, function(yr) {
  files_yr <- nc_files_summer[grepl(paste0("era5_", yr), nc_files_summer)]
  r <- terra::rast(files_yr)          # stack all hours across 3 months
  r <- r - 273.15                     # convert Kelvin to Celsius
  r_max <- max(r)                    
  names(r_max) <- yr
  return(r_max)
})

# Stack all 9 yearly summer max rasters into one
summer_max_stack <- terra::rast(summer_max_list)

# Average summer Tmax across all 9 years
