# homogeneity in population density 
# Idea:
# - quantify how evenly population is distributed across grid pieces inside each province.
# - Gini = 0  -> very homogeneous / evenly spread population
# - Gini = 1  -> very concentrated population

# Gini coefficient function
gini_fun <- function(x) {
  x <- x[is.finite(x) & !is.na(x)]
  x <- x[x >= 0]
  
  if (length(x) == 0) return(NA_real_)
  if (sum(x) == 0) return(0)
  
  x <- sort(x)
  n <- length(x)
  G <- (2 * sum(x * seq_len(n)) / (n * sum(x))) - (n + 1) / n
  return(G)
}

